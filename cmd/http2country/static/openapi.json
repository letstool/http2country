{
  "openapi": "3.1.0",
  "info": {
    "title": "http2country — Country Intelligence API",
    "description": "Returns structured country information from the letstool CDN database. Accepts ISO 3166-1 alpha-2, alpha-3, or numeric country codes (case-insensitive). The database is built automatically from a gzipped CSV at https://cdn.letstool.net/country/csv and refreshed every 24 hours.",
    "version": "1.0.0",
    "license": { "name": "Apache-2.0" }
  },
  "servers": [{ "url": "http://localhost:8080", "description": "Local server" }],
  "paths": {
    "/api/v1/country": {
      "post": {
        "summary": "Look up a country by ISO2, ISO3, or numeric code",
        "description": "Accepts a single country identifier (ISO 3166-1 alpha-2, alpha-3, or numeric). Returns full country intelligence: geography, languages, currencies, legal framework, GDP, GINI, and more.",
        "operationId": "getCountry",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CountryRequest" },
              "examples": {
                "iso2": { "summary": "ISO2 lookup", "value": { "country": "FR" } },
                "iso3": { "summary": "ISO3 lookup", "value": { "country": "FRA" } },
                "numeric": { "summary": "Numeric lookup", "value": { "country": "250" } },
                "lowercase": { "summary": "Lowercase ISO2", "value": { "country": "de" } }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Country lookup result",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CountryResponse" } } }
          },
          "405": { "description": "Method not allowed — only POST is accepted" }
        }
      }
    },
    "/db/country": {
      "get": {
        "summary": "Download the current country.mmdb database file",
        "description": "Serves the current country.mmdb binary for peer synchronisation.",
        "operationId": "getDB",
        "responses": {
          "200": { "description": "country.mmdb binary", "content": { "application/octet-stream": { "schema": { "type": "string", "format": "binary" } } } },
          "404": { "description": "Database not yet built" }
        }
      }
    },
    "/openapi.json": {
      "get": { "summary": "OpenAPI 3.1 specification", "operationId": "getOpenAPI", "responses": { "200": { "description": "OpenAPI JSON", "content": { "application/json": {} } } } }
    },
    "/": {
      "get": { "summary": "Embedded interactive web UI", "operationId": "getUI", "responses": { "200": { "description": "HTML web UI", "content": { "text/html": {} } } } }
    }
  },
  "components": {
    "schemas": {
      "CountryRequest": {
        "type": "object",
        "required": ["country"],
        "properties": {
          "country": {
            "type": "string",
            "description": "ISO 3166-1 alpha-2 (e.g. 'FR'), alpha-3 (e.g. 'FRA'), or numeric (e.g. '250'). Case-insensitive.",
            "example": "FR"
          }
        }
      },
      "CountryResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["SUCCESS", "NOTFOUND", "ERROR"], "description": "SUCCESS: country found. NOTFOUND: unknown code. ERROR: malformed request or DB not ready." },
          "query": { "type": "string", "description": "The original query string." },
          "answer": { "$ref": "#/components/schemas/CountryAnswer" }
        }
      },
      "CountryAnswer": {
        "type": "object",
        "properties": {
          "iso2": { "type": "string", "description": "ISO 3166-1 alpha-2 code (uppercase)." },
          "iso3": { "type": "string", "description": "ISO 3166-1 alpha-3 code (uppercase)." },
          "numeric_code": { "type": "string", "description": "ISO 3166-1 numeric code (zero-padded, e.g. '250')." },
          "fifa": { "type": "string", "description": "FIFA country code." },
          "status": { "type": "string", "description": "Assignment status (e.g. 'officially-assigned')." },
          "independent": { "type": "boolean" },
          "un_member": { "type": "boolean" },
          "name_common": { "type": "string", "description": "Common English name." },
          "name_official": { "type": "string", "description": "Official English name." },
          "region": { "type": "string" },
          "subregion": { "type": "string" },
          "capital": { "type": "string" },
          "latitude": { "type": "number" },
          "longitude": { "type": "number" },
          "area_sq_km": { "type": "number" },
          "landlocked": { "type": "boolean" },
          "borders": { "type": "array", "items": { "type": "string" }, "description": "ISO2 codes of bordering countries." },
          "language_codes": { "type": "array", "items": { "type": "string" } },
          "currency_codes": { "type": "array", "items": { "type": "string" } },
          "tld": { "type": "array", "items": { "type": "string" } },
          "calling_codes": { "type": "array", "items": { "type": "string" } },
          "demonym_eng_m": { "type": "string" },
          "demonym_eng_f": { "type": "string" },
          "gini_year": { "type": "string" },
          "gini_value": { "type": "number" },
          "gdp_current_usd": { "type": "number" },
          "gdp_per_capita_usd": { "type": "number" },
          "gdp_year": { "type": "string" },
          "flag_emoji": { "type": "string" },
          "legal_eu": { "type": "boolean" },
          "legal_eea": { "type": "boolean" },
          "legal_schengen": { "type": "boolean" },
          "legal_gdpr": { "type": "boolean" },
          "legal_data_residency": { "type": "boolean" },
          "legal_vat_rate": { "type": "number" },
          "legal_vat_name": { "type": "string" },
          "legal_digital_vat": { "type": "boolean" },
          "legal_ofac": { "type": "boolean" },
          "legal_eu_sanction": { "type": "boolean" },
          "legal_un_sanction": { "type": "boolean" },
          "legal_fatf": { "type": "string", "description": "FATF status string (e.g. 'grey-list') or empty." }
        }
      }
    }
  }
}
